# FresCoop Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# SERVER
# ============================================================================
PORT=4174
HOST=0.0.0.0
# TOKEN_SECRET=your-random-secret-here-min-32-chars

# ============================================================================
# DATABASE (optional - falls back to local JSON file)
# ============================================================================
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=frescoop
# Set true in production so the server stops instead of falling back to store.json
# FRESCOOP_REQUIRE_MONGODB=true
# Seed mode: auto (local demo only), none (production), demo (force seed-data.json)
# FRESCOOP_SEED_MODE=none

# ============================================================================
# AUTHENTICATION - Admin seed accounts
# ============================================================================
# Comma-separated admin emails (defaults to team emails if not set)
# FRESCOOP_ADMIN_EMAILS=admin1@example.com,admin2@example.com
# SHA-256 hash of admin password (default: team shared password)
# FRESCOOP_ADMIN_PASSWORD_HASH=your-sha256-hash
# FRESCOOP_DEMO_PASSWORD_HASH=your-sha256-hash
# FRESCOOP_MOBILE_DEMO_PASSWORD_HASH=your-sha256-hash

# ============================================================================
# CLOUDINARY (image uploads)
# ============================================================================
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ============================================================================
# PAYDUNYA (payments)
# ============================================================================
# PAYDUNYA_MODE=test
# PAYDUNYA_MASTER_KEY=your-master-key
# PAYDUNYA_PRIVATE_KEY=your-private-key
# PAYDUNYA_TOKEN=your-token
# PAYDUNYA_STORE_NAME=FresCoop

# ============================================================================
# AI CHATBOT (OpenRouter)
# ============================================================================
# OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_MODELS=openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free

# ============================================================================
# CORS (production only)
# ============================================================================
# CORS_ORIGINS=https://your-domain.vercel.app,https://your-custom-domain.com
